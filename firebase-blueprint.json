{
  "entities": {
    "saving": {
      "title": "Saving",
      "description": "Financial asset details",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "type": { "type": "string" },
        "amount": { "type": "number" },
        "currency": { "type": "string" },
        "name": { "type": "string" },
        "createdAt": { "type": "number" },
        "bankName": { "type": "string" },
        "interestRate": { "type": "number" },
        "startDate": { "type": "string" },
        "maturityDate": { "type": "string" },
        "isCapitalized": { "type": "boolean" },
        "symbol": { "type": "string" },
        "shares": { "type": "number" }
      },
      "required": ["id", "userId", "type", "amount", "currency", "name", "createdAt"]
    }
  },
  "firestore": {
    "savings/{savingId}": {
      "schema": "saving",
      "description": "User's financial assets"
    }
  }
}
