rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Global helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Validation for Saving entity
    function isValidSaving(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.userId is string && data.userId == request.auth.uid &&
             data.type is string && data.type.size() <= 50 &&
             data.amount is number &&
             data.currency is string && data.currency.size() <= 3 &&
             data.name is string && data.name.size() <= 100 &&
             data.createdAt is number;
    }

    match /savings/{savingId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isSignedIn() && 
                    isValidId(savingId) && 
                    isValidSaving(incoming()) &&
                    incoming().id == savingId;
      
      allow update: if isSignedIn() && 
                    resource.data.userId == request.auth.uid &&
                    isValidSaving(incoming()) &&
                    incoming().userId == existing().userId &&
                    incoming().id == existing().id &&
                    incoming().createdAt == existing().createdAt;

      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
  }
}
